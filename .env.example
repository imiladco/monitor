# password to log into the dashboard (required — the panel and its API are
# otherwise open to anyone who can reach the port)
ADMIN_PASSWORD=change-me

# Admin session cookie. SECURE_COOKIES=true adds the Secure flag (only works
# once the panel is served over HTTPS — leave false on plain http://).
SESSION_TTL_HOURS=168
SECURE_COOKIES=false

# optional bootstrap defaults — once set from the dashboard's Settings page,
# the panel's values take over and these are ignored
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# minutes between checks
CHECK_INTERVAL_MINUTES=5

# hour (0-23, server local time) to send the daily summary
DAILY_SUMMARY_HOUR=9

# alert when SSL cert expires within this many days
SSL_WARN_DAYS=14

# response time (ms) above which a site is flagged as slow
SLOW_RESPONSE_MS=3000

# request timeout (ms)
REQUEST_TIMEOUT_MS=10000

# dashboard/API port
PORT=4000

# flag a Time Machine event when the DB grows by this % or more between agent snapshots
DB_GROWTH_WARN_PERCENT=20

# hour (0-23) to run visual/Core-Web-Vitals/domain checks (slower, so run once a day)
DEEP_CHECK_HOUR=3

# flag a visual-regression event when this % of homepage pixels changed
VISUAL_DIFF_WARN_PERCENT=15

# flag a Core Web Vitals event when LCP exceeds this many ms
LCP_WARN_MS=4000

# warn when the domain is this many days (or fewer) from expiring
DOMAIN_WARN_DAYS=30

# path to a Chromium executable for screenshots/vitals (playwright-core doesn't bundle one).
# Leave unset if you ran `npx playwright install chromium`, which installs it to the default location.
CHROMIUM_PATH=

# hour (0-23) for the daily SQLite backup + old-log cleanup
BACKUP_HOUR=4

# --- vulnerability (CVE) cross-reference ---
# daily scan enabled (set to "false" to disable)
VULN_SYNC_ENABLED=true
# hour (0-23) to run the vulnerability scan (after backup + deep checks)
VULN_SYNC_HOUR=5
# minimum severity that triggers a Telegram alert (low|medium|high|critical)
VULN_ALERT_MIN_SEVERITY=high
# optional external vulnerability feed (JSON array in the internal shape).
# leave empty to run on the local seed DB alone. add a bearer key if the feed needs one.
EXTERNAL_VULN_FEED_URL=
EXTERNAL_VULN_FEED_KEY=
